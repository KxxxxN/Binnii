    "privacy_intro" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Binnii Application Project Team, College of Social Communication Innovation, Srinakharinwirot University (hereinafter referred to as the \"Project Team\") hereby informs you of the practices for collecting, using, processing, or disclosing personal data of users, in accordance with the Personal Data Protection Act B.E. 2562 (2019), as follows:"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "คณะผู้จัดทำโครงการแอปพลิเคชัน Binnii วิทยาลัยนวัตกรรมสื่อสารสังคม มหาวิทยาลัยศรีนครินทรวิโรฒ (ซึ่งต่อไปนี้เรียกว่า “คณะผู้จัดทำ”) ขอแจ้งให้ท่านทราบถึงหลักปฏิบัติในการเก็บรวบรวม ใช้ ประมวลผล หรือเปิดเผยข้อมูลส่วนบุคคลของผู้ใช้งาน ตามพระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 ดังต่อไปนี้"
          }
        }
      }
    },
