    "privacy_section1_personal_data" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Personal Data\" means information about an individual that enables the identification of that person, whether directly or indirectly, such as name-surname, student ID, or email address."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "“ข้อมูลส่วนบุคคล” หมายถึง ข้อมูลเกี่ยวกับบุคคลซึ่งทำให้สามารถระบุตัวตนบุคคลนั้นได้ไม่ว่าทางตรงหรือทางอ้อม เช่น ชื่อ-นามสกุล, รหัสนิสิต, อีเมล"
          }
        }
      }
    },
    "privacy_section1_sensitive_data" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sensitive Personal Data\" means data as defined under Section 26 of the PDPA, including biometric data (facial image models) and photographs that may identify specific characteristics for use in AI processing."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "“ข้อมูลส่วนบุคคลที่มีความอ่อนไหว” หมายถึง ข้อมูลตามมาตรา ๒๖ แห่งกฎหมาย PDPA รวมถึงข้อมูลชีวภาพ (ภาพจำลองใบหน้า) และภาพถ่ายที่อาจระบุลักษณะเฉพาะตัวเพื่อใช้ในการประมวลผลของ AI"
          }
        }
      }
    },
