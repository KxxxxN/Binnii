    "faq_a1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The system uses the camera to scan waste and analyzes it with AI to automatically identify the type of waste, along with proper disposal or recycling suggestions"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ระบบจะใช้กล้องสแกนขยะ และวิเคราะห์ด้วย AI เพื่อระบุประเภทขยะให้โดยอัตโนมัติ พร้อมแนะนำวิธีทิ้งหรือรีไซเคิลอย่างถูกต้อง"
          }
        }
      }
    },
    "faq_a2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It may be caused by an unclear image, low light, or incomplete object. It is recommended to scan in a bright place. Hold the camera still and keep the object in full frame."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "อาจเกิดจากภาพไม่ชัด แสงน้อย หรือเห็นวัตถุไม่ครบถ้วน แนะนำให้สแกนในที่สว่าง ถือกล้องให้นิ่ง และให้วัตถุอยู่เต็มกรอบภาพ"
          }
        }
      }
    },
    "faq_a3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
