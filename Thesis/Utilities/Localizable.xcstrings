      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3.1 Received directly from the application when you register or log in."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "3.1 ได้รับโดยตรงจากแอปพลิเคชันขณะที่ท่านลงทะเบียนหรือเข้าใช้งาน"
          }
        }
      }
    },
    "privacy_section3_point2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3.2 Photographic data that you submit for processing through the in-app camera."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "3.2 ข้อมูลภาพถ่ายที่ท่านส่งเข้าประมวลผลผ่านกล้องถ่ายภาพภายในแอปพลิเคชัน"
          }
        }
      }
    },
