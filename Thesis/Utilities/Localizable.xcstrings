    "privacy_section4_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4. Purposes of Data Processing"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "4. วัตถุประสงค์ในการประมวลผลข้อมูล"
          }
        }
      }
    },
    "privacy_section5_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Project Team will retain your personal data for the duration of your use of the application, or throughout the research project (Thesis) period, and may retain it further as required by law or for verification purposes in accordance with university criteria."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "คณะผู้จัดทำจะจัดเก็บข้อมูลส่วนบุคคลของท่านตลอดระยะเวลาที่ท่านยังเป็นผู้ใช้งานแอปพลิเคชัน หรือตลอดระยะเวลาการดำเนินโครงการวิจัย (Thesis) และอาจเก็บต่อไปตามระยะเวลาที่กฎหมายกำหนดหรือเพื่อวัตถุประสงค์ในการพิสูจน์ตรวจสอบตามเกณฑ์ของมหาวิทยาลัย"
          }
        }
      }
    },
    "privacy_section5_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5. Data Retention Period"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "5. ระยะเวลาในการจัดเก็บข้อมูล"
          }
        }
      }
    },
    "privacy_section6_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6.1 Disclosure: Data may be disclosed to the College of Social Communication Innovation or relevant internal university departments for the purpose of summarizing waste management statistics."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "6.1 การเปิดเผย: อาจเปิดเผยข้อมูลแก่ วิทยาลัยนวัตกรรมสื่อสารสังคม หรือหน่วยงานภายในมหาวิทยาลัยที่เกี่ยวข้อง เพื่อสรุปผลสถิติการจัดการขยะ"
          }
        }
      }
    },
    "privacy_section6_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6. Disclosure and Transfer of Personal Data"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "6. การเปิดเผยและโอนข้อมูลส่วนบุคคล"
          }
        }
      }
    },
    "privacy_section7_point1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "7.1 Access to data is restricted to relevant Project Team members only."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "7.1 จำกัดการเข้าถึงข้อมูลเฉพาะคณะผู้จัดทำที่เกี่ยวข้องเท่านั้น"
          }
        }
      }
    },
    "privacy_section7_point2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "7.2 Important data is encrypted and a secure login system is used in accordance with university security practices."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "7.2 มีการเข้ารหัสข้อมูลสำคัญและใช้ระบบ Login ที่มีความปลอดภัยตามแนวปฏิบัติของมหาวิทยาลัย"
          }
        }
      }
    },
    "privacy_section7_point3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "7.3 Data backup and recovery systems are in place in accordance with the project management plan."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "7.3 มีการสำรองข้อมูลและระบบกู้คืนข้อมูลตามแผนจัดการของโครงการ"
          }
        }
      }
    },
    "privacy_section7_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "7. Security Measures"
          }
        },
        "th" : {
